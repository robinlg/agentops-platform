### 变量声明（VSCode REST Client 使用；GoLand 会优先读 http-client.env.json）
@baseUrl = http://127.0.0.1:38443
@apiPrefix = /v1
@resource = {{baseUrl}}{{apiPrefix}}/model-providers
# 如果不想依赖 Create 响应，可以在此手动指定一个已有 id
@id = 1


### 1. 创建 ModelProvider
# @name createModelProvider
POST {{resource}}
Content-Type: application/json

{
  "name": "openai-test",
  "provider_type": "openai",
  "base_url": "https://api.openai.com/v1",
  "api_key": "sk-test-xxxxxxxxxxxxxxxx",
  "default_model": "gpt-4o-mini"
}

> {%
    // 把 create 响应里的 id 存到全局变量，供后续 Get/Update/Delete 复用
    // GoLand 语法
    if (response.body && response.body.id) {
        client.global.set("createdId", response.body.id);
    }
%}


### 2. 列表查询 ModelProvider
GET {{resource}}?offset=0&limit=10
Accept: application/json


### 3. 获取单个 ModelProvider
# 使用第 1 步创建返回的 id；如未跑第 1 步，可改成上方的 {{id}}
GET {{resource}}/{{createdId}}
Accept: application/json


### 4. 更新 ModelProvider（部分更新，字段均为 optional）
PUT {{resource}}/{{createdId}}
Content-Type: application/json

{
  "name": "openai-test-updated",
  "default_model": "gpt-4o"
}


### 5. 更新后再次 Get 校验
GET {{resource}}/{{createdId}}
Accept: application/json


### 6. 删除 ModelProvider
DELETE {{resource}}/{{createdId}}


### 7. 删除后再次列表校验
GET {{resource}}?offset=0&limit=10
Accept: application/json
